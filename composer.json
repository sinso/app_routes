{
  "name": "sinso/app-routes",
  "type": "typo3-cms-extension",
  "description": "Easy way to route rest-like URLs to your code",
  "license": "GPL-2.0-only",
  "require": {
    "typo3/cms-core": "^13.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1"
  },
  "scripts": {
    "phpstan": "phpstan analyze -c phpstan.neon --memory-limit=1G"
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  },
  "autoload": {
    "psr-4": {
      "Sinso\\AppRoutes\\": "Classes"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "app_routes"
    }
  }
}
